{
  "manifest_version": 3,
  "name": "Meet Coach — Sova Health",
  "version": "3.0.0",
  "description": "AI-powered call coach for Sova Health teams",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://api.anthropic.com/*",
    "https://script.google.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Meet Coach"
  },
  "web_accessible_resources": [
    {
      "resources": ["onboarding.html", "admin.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
